<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FrozenThrone Players</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="site-bg">
<header class="navbar">
  <div class="nav-inner">
    <a class="logo" href="/">FrozenThrone<small>WotLK 3.3.5a</small></a>
    <nav class="nav-links">
      <a href="/">Home</a>
      <a href="/news.html">News</a>
      <a href="/players.html">Players</a>
      <a href="/features.html">Features</a>
      <a href="/download.html">Download</a>
      <a href="/register">Register</a>
      <a href="/shop.html">Shop</a>
    </nav>
    <div class="nav-actions">
      <span class="status-dot" id="realm-status-small">Realm</span>
      <a class="btn" href="/register">Play Now</a>
    </div>
  </div>
</header>
<main class="container">
  <section>
    <div class="section-head"><h1>Player Rankings</h1><p>Styled ranking tables ready for TrinityCore database integration.</p></div>
    <div class="grid grid-2">
      <div class="card"><h3>Top Level Players</h3><div class="table-wrap"><table class="rank-table"><thead><tr><th>Rank</th><th>Name</th><th>Level</th><th>Class</th></tr></thead><tbody><tr><td>1</td><td>Coming Soon</td><td>-</td><td>-</td></tr><tr><td>2</td><td>Coming Soon</td><td>-</td><td>-</td></tr><tr><td>3</td><td>Coming Soon</td><td>-</td><td>-</td></tr></tbody></table></div></div>
      <div class="card"><h3>Top Gold</h3><div class="table-wrap"><table class="rank-table"><thead><tr><th>Rank</th><th>Name</th><th>Gold</th></tr></thead><tbody><tr><td>1</td><td>Coming Soon</td><td>-</td></tr><tr><td>2</td><td>Coming Soon</td><td>-</td></tr><tr><td>3</td><td>Coming Soon</td><td>-</td></tr></tbody></table></div></div>
      <div class="card"><h3>Top Achievement Points</h3><div class="table-wrap"><table class="rank-table"><thead><tr><th>Rank</th><th>Name</th><th>Points</th></tr></thead><tbody><tr><td>1</td><td>Coming Soon</td><td>-</td></tr><tr><td>2</td><td>Coming Soon</td><td>-</td></tr><tr><td>3</td><td>Coming Soon</td><td>-</td></tr></tbody></table></div></div>
      <div class="card"><h3>Top Honorable Kills</h3><div class="table-wrap"><table class="rank-table"><thead><tr><th>Rank</th><th>Name</th><th>Kills</th></tr></thead><tbody><tr><td>1</td><td>Coming Soon</td><td>-</td></tr><tr><td>2</td><td>Coming Soon</td><td>-</td></tr><tr><td>3</td><td>Coming Soon</td><td>-</td></tr></tbody></table></div></div>
      <div class="card highlight"><h3>Recently Online</h3><div class="table-wrap"><table class="rank-table"><thead><tr><th>Name</th><th>Level</th><th>Last Seen</th></tr></thead><tbody><tr><td>Coming Soon</td><td>-</td><td>-</td></tr><tr><td>Coming Soon</td><td>-</td><td>-</td></tr><tr><td>Coming Soon</td><td>-</td><td>-</td></tr></tbody></table></div></div>
      <div class="card highlight"><h3>Realm Totals</h3><div class="grid grid-3"><div class="stat"><span>Accounts</span><strong id="accounts">0</strong></div><div class="stat"><span>Characters</span><strong id="characters">0</strong></div><div class="stat"><span>Online</span><strong id="online">0</strong></div></div></div>
    </div>
  </section>
</main>
<footer class="footer">
  <strong>FrozenThrone</strong> © 2026 · Wrath of the Lich King 3.3.5a · Blizzlike x1 Realm
  <div class="footer-links">
    <a href="/news.html">News</a>
    <a href="/players.html">Players</a>
    <a href="/download.html">Download</a>
    <a href="/register">Create Account</a>
  </div>
</footer>
</div>
<script>
fetch('/stats')
  .then(res => res.json())
  .then(data => {
    const status = data.status || 'Online';
    const set = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value; };
    set('realm-status-small', status);
    set('status', status);
    set('accounts', data.accounts ?? '0');
    set('characters', data.characters ?? '0');
    set('online', data.online ?? '0');
  })
  .catch(() => {
    const set = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value; };
    set('realm-status-small', 'Offline');
    set('status', 'Offline');
  });
</script>
</body>
</html>